# Binance credentials
BINANCE_API_KEY=
BINANCE_SECRET=

# paper | live
BOT_MODE=paper

# manual | auto
EXECUTION_MODE=manual

# none | discord | terminal
APPROVAL_MODE=discord

# true | false
ENABLE_LIVE_TRADING=false
USE_TESTNET=true
RECONCILE_ON_START=true
ORDER_TEST_BEFORE_SUBMIT=false

# Optional override if Binance changes a base URL again.
# Leave blank unless you need it.
BINANCE_API_BASE_URL=
RECV_WINDOW_MS=5000

# Trading pair, example: SOL/USDT, ETH/USDT, BTC/USDT
# BINANCE_SELECTION_MODE=manual keeps this as-is.
SYMBOL=SOL/USDT
BINANCE_SELECTION_MODE=manual
BINANCE_SELECTION_CSV=data/market/binance_candidates.csv
BINANCE_SELECTION_ROTATE_EVERY_LOOPS=0
BINANCE_SELECTION_ROTATE_ONLY_WHEN_FLAT=true

# Main execution timeframe, example: 5m, 15m, 1h
TIMEFRAME=15m

# Starting paper balance
STARTING_BALANCE=100

# Risk model
RISK_PER_TRADE=0.01
STOP_LOSS_PCT=0.02
TAKE_PROFIT_PCT=0.03
COOLDOWN_CANDLES=2
MAX_TRADE_USD=5
MAX_DAILY_LOSS_USD=1
MAX_TRADES_PER_DAY=3
FEE_RATE=0.001
SLIPPAGE_BUFFER_PCT=0.001
ENTRY_SIZE_MODE=quote_budget

# true | false
KILL_SWITCH=false

# Polling / status
POLL_SECONDS=30
STATUS_EVERY_LOOPS=10

# Discord webhook URL for alerts/tickets/status. Leave blank to disable Discord messages.
DISCORD_WEBHOOK_URL=

# Main timeframe RSI filter
USE_RSI_FILTER=true
RSI_BUY_MIN=52
RSI_SELL_MAX=48
RSI_PERIOD=14

# Higher timeframe RSI filter(s)
USE_HTF_FILTER=false
HTF_1_TIMEFRAME=4h
HTF_1_RSI_MIN=50
HTF_1_RSI_PERIOD=14
HTF_2_ENABLED=false
HTF_2_TIMEFRAME=1d
HTF_2_RSI_MIN=50
HTF_2_RSI_PERIOD=14

# Use the last fully closed candle for strategy decisions.
SIGNAL_ON_CLOSED_CANDLE=true

# Optional Binance runtime paths
BINANCE_STATE_PATH=data/state/runtime_state.json
BINANCE_TRADES_PATH=data/logs/trades.csv
BINANCE_TICKETS_PATH=data/logs/manual_tickets.csv
BINANCE_DECISION_LOG_PATH=data/logs/decision_log.csv
BINANCE_EXECUTION_LOG_PATH=data/logs/live_execution_log.csv
BINANCE_BACKTEST_OUTPUT_PATH=data/backtests/backtest_trades.csv

# Polymarket
POLYMARKET_HOST=https://clob.polymarket.com
# PM_SELECTION_MODE=manual keeps this token id as-is.
POLYMARKET_TOKEN_ID=75467129615908319583031474642658885479135630431889036121812713428992454630178
PM_SELECTION_MODE=manual
PM_SELECTION_CSV=data/market/polymarket_candidates.csv
PM_SELECTION_ROTATE_EVERY_LOOPS=0
PM_SELECTION_ROTATE_ONLY_WHEN_FLAT=true
PM_PAPER_MODE=true
PM_MIN_ORDER_SIZE=5
PM_QUOTE_SIZE=25
PM_BASE_SPREAD=0.04
PM_EDGE_OFFSET=0.01
PM_INVENTORY_TARGET=0
PM_MAX_INVENTORY=100
PM_MAX_POSITION_NOTIONAL=60
PM_INVENTORY_SKEW_PER_SHARE=0.0025
PM_POLL_SECONDS=5
PM_LOOPS=20
PM_STATE_PATH=data/state/polymarket_state.json
PM_LOG_PATH=data/logs/polymarket_runs.csv
