# Binance credentials are NOT required for the current supervised/manual setup.
# Leave blank unless you later build something that needs private account access.
BINANCE_API_KEY=
BINANCE_SECRET=

# paper | live
# Current build supports paper/supervised manual mode only.
BOT_MODE=paper

# Trading pair, example: SOL/USDT, ETH/USDT, BTC/USDT
SYMBOL=SOL/USDT

# Main execution timeframe, example: 5m, 15m, 1h
TIMEFRAME=15m

# Starting fake balance for paper/supervised tracking
STARTING_BALANCE=100

# Fraction of balance risk budget per trade. Example: 0.01 = 1%
# Current validation allows 0 < value <= 0.05
RISK_PER_TRADE=0.01

# Stop loss / take profit percentages. Example: 0.02 = 2%
STOP_LOSS_PCT=0.02
TAKE_PROFIT_PCT=0.03

# Number of candles to wait after exit before allowing a new entry
COOLDOWN_CANDLES=2

# true | false
# Emergency stop for the bot loop
KILL_SWITCH=false

# Poll interval in seconds for checking new market data
POLL_SECONDS=30

# How often to send periodic status messages. Example: 10 = every 10 loops.
# Set to 1 if you want to preview prettier Discord status formatting quickly.
# Set to 0 to disable periodic status messages.
STATUS_EVERY_LOOPS=10

# Discord webhook URL for alerts/tickets/status. Leave blank to disable Discord messages.
DISCORD_WEBHOOK_URL=

# true | false
# Enable 15m RSI filter on top of EMA logic
USE_RSI_FILTER=true

# RSI buy/sell thresholds for the main timeframe
RSI_BUY_MIN=52
RSI_SELL_MAX=48

# RSI period for the main timeframe
RSI_PERIOD=14

# true | false
# Enable higher-timeframe RSI filter(s)
USE_HTF_FILTER=false

# First higher-timeframe filter settings
# Common values: 1h, 4h, 1d
HTF_1_TIMEFRAME=4h
HTF_1_RSI_MIN=50
HTF_1_RSI_PERIOD=14

# true | false
# Optional second HTF filter layer
HTF_2_ENABLED=false

# Second higher-timeframe filter settings
# Common values: 4h, 1d
HTF_2_TIMEFRAME=1d
HTF_2_RSI_MIN=50
HTF_2_RSI_PERIOD=14

# true | false
# If true, strategy decisions use the last fully closed candle.
# Recommended: true
SIGNAL_ON_CLOSED_CANDLE=true

# discord | terminal
# discord = ticket messages are sent to Discord; decision phrases are just workflow hints.
# terminal = bot can prompt locally for approve/deny logging.
APPROVAL_MODE=discord

# manual
# Current build supports manual execution tickets only.
EXECUTION_MODE=manual

# Max suggested notional per ticket in USD
MAX_TRADE_USD=5

# Max allowed realized loss per day before new tickets are blocked
MAX_DAILY_LOSS_USD=1

# true | false
# Present for future compatibility, but live execution is still blocked in this build.
ENABLE_LIVE_TRADING=false
