# Binance credentials
BINANCE_API_KEY=
BINANCE_SECRET=

# paper | live | live_readonly
BOT_MODE=paper

# manual | auto
EXECUTION_MODE=manual

# none | discord | terminal
APPROVAL_MODE=discord

# true | false
ENABLE_LIVE_TRADING=false
USE_TESTNET=true
RECONCILE_ON_START=true
ORDER_TEST_BEFORE_SUBMIT=false

# Optional override if Binance changes a base URL again.
# Leave blank unless you need it.
BINANCE_API_BASE_URL=
RECV_WINDOW_MS=5000

# Trading pair, example: SOL/USDT, ETH/USDT, BTC/USDT
# BINANCE_SELECTION_MODE=manual keeps this as-is.
SYMBOL=SOL/USDT
BINANCE_SELECTION_MODE=manual
# auto | manual | trend | range | volatile | slow_liquid
# Blank means auto in BINANCE_SELECTION_MODE=csv/scan and manual otherwise.
BINANCE_STRATEGY_PROFILE=
BINANCE_SELECTION_CSV=data/market/binance_candidates.csv
BINANCE_SELECTION_ROTATE_EVERY_LOOPS=0
BINANCE_SELECTION_ROTATE_ONLY_WHEN_FLAT=true

# Main execution timeframe, example: 5m, 15m, 1h
TIMEFRAME=15m

# Base EMA settings used when no profile override is active.
EMA_FAST_PERIOD=9
EMA_SLOW_PERIOD=21

# Starting paper balance
STARTING_BALANCE=100

# Risk model
RISK_PER_TRADE=0.01
STOP_LOSS_PCT=0.02
TAKE_PROFIT_PCT=0.03
COOLDOWN_CANDLES=2
MAX_TRADE_USD=5
MAX_DAILY_LOSS_USD=1
MAX_TRADES_PER_DAY=3
FEE_RATE=0.001
SLIPPAGE_BUFFER_PCT=0.001
ENTRY_SIZE_MODE=quote_budget

# true | false
KILL_SWITCH=false

# Polling / status
POLL_SECONDS=30
STATUS_EVERY_LOOPS=10

# Discord webhook URL for alerts/tickets/status. Leave blank to disable Discord messages.
DISCORD_WEBHOOK_URL=

# Main timeframe RSI filter
USE_RSI_FILTER=true
RSI_BUY_MIN=52
RSI_SELL_MAX=48
RSI_PERIOD=14

# Recent-history adaptive overlay (opt-in)
# off | paper | on
# paper = only apply the adaptive overlay when BOT_MODE=paper
BINANCE_ADAPTIVE_MODE=off
BINANCE_ADAPTIVE_REPORT_PATH=data/market/binance_adaptive_report.txt
BINANCE_READONLY_REPORT_PATH=data/market/binance_live_readonly_report.txt
BINANCE_READONLY_REPORT_JSON_PATH=data/market/binance_live_readonly_report.json
BINANCE_READONLY_COMPACT_INTERVAL_SECONDS=120
BINANCE_READONLY_HEARTBEAT_INTERVAL_SECONDS=1800

# Live read-only / dry-run mode against a real Binance account.
# This mode never submits, tests, or cancels orders.
# BOT_MODE=live_readonly
# ENABLE_LIVE_TRADING=false
# USE_TESTNET=false
# EXECUTION_MODE=auto
# BINANCE_SELECTION_MODE=scan
# BINANCE_STRATEGY_PROFILE=auto
# BINANCE_ADAPTIVE_MODE=paper

# Higher timeframe RSI filter(s)
USE_HTF_FILTER=false
HTF_1_TIMEFRAME=4h
HTF_1_RSI_MIN=50
HTF_1_RSI_PERIOD=14
HTF_2_ENABLED=false
HTF_2_TIMEFRAME=1d
HTF_2_RSI_MIN=50
HTF_2_RSI_PERIOD=14

# Use the last fully closed candle for strategy decisions.
SIGNAL_ON_CLOSED_CANDLE=true

# Optional Binance runtime paths
BINANCE_STATE_PATH=data/state/runtime_state.json
BINANCE_TRADES_PATH=data/logs/trades.csv
BINANCE_TICKETS_PATH=data/logs/manual_tickets.csv
BINANCE_DECISION_LOG_PATH=data/logs/decision_log.csv
BINANCE_EXECUTION_LOG_PATH=data/logs/live_execution_log.csv
BINANCE_BACKTEST_OUTPUT_PATH=data/backtests/backtest_trades.csv

# Portfolio foundation (Binance-first, Polymarket-ready)
PORTFOLIO_VENUE=binance
PORTFOLIO_SELECTION_MODE=scan
PORTFOLIO_RUN_MODE=paper
PORTFOLIO_STARTING_BALANCE=100
PORTFOLIO_SELECTION_CSV=data/market/portfolio_candidates.csv
PORTFOLIO_STATE_PATH=data/state/portfolio_state.json
PORTFOLIO_REPORT_PATH=data/market/portfolio_allocation_report.txt
PORTFOLIO_REPORT_JSON_PATH=data/market/portfolio_allocation_report.json
PORTFOLIO_CANDIDATE_LIMIT=20
PORTFOLIO_INCLUDE_REJECTED=true
PORTFOLIO_TOP_REPORT_ROWS=8
PORTFOLIO_PAPER_APPLY_ALLOCATIONS=true
PORTFOLIO_MAX_POSITIONS=3
PORTFOLIO_MAX_POSITIONS_PER_VENUE=3
PORTFOLIO_MAX_NEW_POSITIONS_PER_RUN=2
PORTFOLIO_MAX_TOTAL_NOTIONAL=15
PORTFOLIO_MAX_POSITION_NOTIONAL=5
PORTFOLIO_MAX_VENUE_NOTIONAL=10
PORTFOLIO_RESERVE_CASH_USD=70
PORTFOLIO_RESERVE_CASH_PCT=0.70
PORTFOLIO_MIN_CANDIDATE_SCORE=65
PORTFOLIO_MIN_ENTRY_NOTIONAL=5
PORTFOLIO_MAX_SYMBOL_POSITIONS=1
PORTFOLIO_ALLOW_SCALE_UP_EXISTING=false

# Polymarket
POLYMARKET_HOST=https://clob.polymarket.com
# PM_SELECTION_MODE=manual keeps this token id as-is.
POLYMARKET_TOKEN_ID=75467129615908319583031474642658885479135630431889036121812713428992454630178
PM_SELECTION_MODE=manual
PM_SELECTION_CSV=data/market/polymarket_candidates.csv
PM_SELECTION_ROTATE_EVERY_LOOPS=0
PM_SELECTION_ROTATE_ONLY_WHEN_FLAT=true
PM_PAPER_MODE=true
# off = disabled
# paper = only apply adaptive overlay when PM_PAPER_MODE=true
# on = always apply adaptive overlay
PM_ADAPTIVE_MODE=off
PM_ADAPTIVE_REPORT_PATH=data/market/polymarket_adaptive_report.txt
PM_MIN_ORDER_SIZE=5
PM_QUOTE_SIZE=25
PM_STARTING_CASH=100
PM_RESERVE_CASH=25
PM_MAX_DRAWDOWN_PCT=0.15
PM_BASE_SPREAD=0.04
PM_EDGE_OFFSET=0.01
PM_INVENTORY_TARGET=0
PM_MAX_INVENTORY=100
PM_MAX_POSITION_NOTIONAL=60
PM_INVENTORY_SKEW_PER_SHARE=0.0025
PM_POLL_SECONDS=5
PM_LOOPS=20
PM_STATE_PATH=data/state/polymarket_state.json
PM_LOG_PATH=data/logs/polymarket_runs.csv
